\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Locating versus visiting: cost rises with rarity; being reached does not.} (\textbf  {A})~Cost on the linear $y$-axis ($0$ to $8$) versus number of alternatives $K$ on a logarithmic $x$-axis ($2$ to $256$). The locating cost (blue step) follows $\beta \lceil \log _{2}K\rceil $ from Theorem~\ref {thm:locating-cost}, while the visiting cost (red) is identically zero for all $K$: singling a region out is priced and the price grows with the alternatives, whereas a traversal's passing through it is free (Theorem~\ref {thm:asymmetry}). (\textbf  {B})~Locating cost on the linear $y$-axis ($1$ to $8$) versus $\log _{2}(1/p)$ on the linear $x$-axis ($1$ to $8$), where $p=1/K$ is the target's probability. The relation is linear with slope $\beta $: the cost of locating scales with the logarithm of the target's rarity, the quantitative refinement of detectability promised in Theorem~\ref {thm:locating-cost}. (\textbf  {C})~Visiting frequency $\bar  f_{W}$ on a logarithmic $y$-axis ($\sim \!3.9\times 10^{-3}$ to $0.5$) versus region probability $p(W)$ on a logarithmic $x$-axis (same range). The data lie exactly on the identity $\bar  f_{W}=p(W)$, the ergodic-average clause of Theorem~\ref {thm:asymmetry}(iii): rarity enters a visit only through its frequency, never through its cost or possibility. (\textbf  {D})~Three-dimensional surface of locating cost $\beta \lceil \log _{2}K\rceil $ over $\log _{2}K$ ($1$ to $8$) and floor $\beta $ ($0.5$ to $2$), magma colourmap. The cost rises linearly in both $\log _{2}K$ and $\beta $ and is bounded away from zero whenever $\beta >0$: there is no free locating, and the dependence on rarity is logarithmic throughout. Viewing angle: elevation $22^{\circ }$, azimuth $-55^{\circ }$.}}{20}{figure.5}\protected@file@percent }
\newlabel{fig:panel-locating-visiting}{{5}{20}{\textbf {Locating versus visiting: cost rises with rarity; being reached does not.} (\textbf {A})~Cost on the linear $y$-axis ($0$ to $8$) versus number of alternatives $K$ on a logarithmic $x$-axis ($2$ to $256$). The locating cost (blue step) follows $\beta \lceil \log _{2}K\rceil $ from Theorem~\ref {thm:locating-cost}, while the visiting cost (red) is identically zero for all $K$: singling a region out is priced and the price grows with the alternatives, whereas a traversal's passing through it is free (Theorem~\ref {thm:asymmetry}). (\textbf {B})~Locating cost on the linear $y$-axis ($1$ to $8$) versus $\log _{2}(1/p)$ on the linear $x$-axis ($1$ to $8$), where $p=1/K$ is the target's probability. The relation is linear with slope $\beta $: the cost of locating scales with the logarithm of the target's rarity, the quantitative refinement of detectability promised in Theorem~\ref {thm:locating-cost}. (\textbf {C})~Visiting frequency $\bar f_{W}$ on a logarithmic $y$-axis ($\sim \!3.9\times 10^{-3}$ to $0.5$) versus region probability $p(W)$ on a logarithmic $x$-axis (same range). The data lie exactly on the identity $\bar f_{W}=p(W)$, the ergodic-average clause of Theorem~\ref {thm:asymmetry}(iii): rarity enters a visit only through its frequency, never through its cost or possibility. (\textbf {D})~Three-dimensional surface of locating cost $\beta \lceil \log _{2}K\rceil $ over $\log _{2}K$ ($1$ to $8$) and floor $\beta $ ($0.5$ to $2$), magma colourmap. The cost rises linearly in both $\log _{2}K$ and $\beta $ and is bounded away from zero whenever $\beta >0$: there is no free locating, and the dependence on rarity is logarithmic throughout. Viewing angle: elevation $22^{\circ }$, azimuth $-55^{\circ }$}{figure.5}{}}
\newlabel{fig:panel-locating-visiting@cref}{{[figure][5][]5}{[1][19][]20}{}{}{}}
