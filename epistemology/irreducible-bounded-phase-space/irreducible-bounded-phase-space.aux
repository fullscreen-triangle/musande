\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Detectability: a region is distinguishable exactly when it clears its own separator.} (\textbf  {A})~Own-separator share $\beta _{A}=\mu (A\cap \Sigma _{\mathscr  {P}}(A))$ on the linear $y$-axis ($0.5$ to $16$) versus region scale $\sigma (A)$ on the linear $x$-axis ($0.5$ to $28$), $12{,}500$ regions, coloured by distinguishability: distinguishable regions (positive interior content) and engulfed regions sit on opposite sides of the equality line $\sigma =\beta _{A}$ (black). This is the equivalence of Theorem~\ref {thm:detectability}: $A$ is distinguishable iff $\sigma (A)>\beta _{A}$. (\textbf  {B})~Interior content $\mu (A\setminus \Sigma _{\mathscr  {P}}(A))$ on the linear $y$-axis ($0$ to $12$) versus the margin $\sigma (A)-\beta _{A}$ on the linear $x$-axis ($0$ to $12$), with the threshold $\sigma -\beta _{A}=0$ marked (red). Interior content is positive precisely when the margin is positive---in fact the two coincide by the cell decomposition $\sigma =\text  {interior}+\beta _{A}$---making the detectability criterion an identity rather than an approximation. (\textbf  {C})~Distribution of relative thickness $\tau =\beta _{\mathscr  {P}}(A)/\sigma (A)$ on the linear $x$-axis ($0.86$ to $5$), counts on the linear $y$-axis, threshold $\tau =1$ marked (red). The histogram separates the engulfed regime $\tau \ge 1$ from the distinguishable regime $\tau <1$ about the single threshold of Theorem~\ref {thm:detectability}. (\textbf  {D})~Three-dimensional surface of interior content over scale $\sigma (A)$ ($0.5$ to $28$) and own-separator share $\beta _{A}$ ($0.5$ to $16$), $12{,}500$ regions, cividis colourmap. Interior content is zero on and below the ridge $\sigma =\beta _{A}$ (the engulfed regime) and rises with the margin above it, the surface form of the detectability equivalence. Viewing angle: elevation $24^{\circ }$, azimuth $-58^{\circ }$.}}{11}{figure.2}\protected@file@percent }
\newlabel{fig:panel-detectability}{{2}{11}{\textbf {Detectability: a region is distinguishable exactly when it clears its own separator.} (\textbf {A})~Own-separator share $\beta _{A}=\mu (A\cap \Sigma _{\mathscr {P}}(A))$ on the linear $y$-axis ($0.5$ to $16$) versus region scale $\sigma (A)$ on the linear $x$-axis ($0.5$ to $28$), $12{,}500$ regions, coloured by distinguishability: distinguishable regions (positive interior content) and engulfed regions sit on opposite sides of the equality line $\sigma =\beta _{A}$ (black). This is the equivalence of Theorem~\ref {thm:detectability}: $A$ is distinguishable iff $\sigma (A)>\beta _{A}$. (\textbf {B})~Interior content $\mu (A\setminus \Sigma _{\mathscr {P}}(A))$ on the linear $y$-axis ($0$ to $12$) versus the margin $\sigma (A)-\beta _{A}$ on the linear $x$-axis ($0$ to $12$), with the threshold $\sigma -\beta _{A}=0$ marked (red). Interior content is positive precisely when the margin is positive---in fact the two coincide by the cell decomposition $\sigma =\text {interior}+\beta _{A}$---making the detectability criterion an identity rather than an approximation. (\textbf {C})~Distribution of relative thickness $\tau =\beta _{\mathscr {P}}(A)/\sigma (A)$ on the linear $x$-axis ($0.86$ to $5$), counts on the linear $y$-axis, threshold $\tau =1$ marked (red). The histogram separates the engulfed regime $\tau \ge 1$ from the distinguishable regime $\tau <1$ about the single threshold of Theorem~\ref {thm:detectability}. (\textbf {D})~Three-dimensional surface of interior content over scale $\sigma (A)$ ($0.5$ to $28$) and own-separator share $\beta _{A}$ ($0.5$ to $16$), $12{,}500$ regions, cividis colourmap. Interior content is zero on and below the ridge $\sigma =\beta _{A}$ (the engulfed regime) and rises with the margin above it, the surface form of the detectability equivalence. Viewing angle: elevation $24^{\circ }$, azimuth $-58^{\circ }$}{figure.2}{}}
\newlabel{fig:panel-detectability@cref}{{[figure][2][]2}{[1][10][]11}{}{}{}}
