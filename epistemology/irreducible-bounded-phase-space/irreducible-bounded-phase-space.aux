\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {The three derivations of the floor bound one constant.} (\textbf  {A})~Representational floor on the linear $y$-axis ($1.5$ to $8$) versus geometric floor on the linear $x$-axis ($1.5$ to $24$), one point per instance ($300$ spaces), with the equality diagonal (red). Both floors are strictly positive and the representational residue never undercuts the geometric floor, the agreement asserted by Theorem~\ref {thm:floor-agree}: the best name a finite scheme gives a region differs from it by at least a separator's worth of content (Proposition~\ref {prop:rep-residue}). (\textbf  {B})~Cost floor on the linear $y$-axis ($0.5$ to $8$) versus geometric floor on the linear $x$-axis ($1.5$ to $24$), $300$ instances, equality diagonal (red). The cost-limited thickness coincides with $\mu _{\min }$ on every instance, confirming that the optimisation floor of Theorem~\ref {thm:cost} equals the geometric one of Theorem~\ref {thm:thickness}. (\textbf  {C})~The refinement cost $g(t)=-\log t$ on the linear $y$-axis ($0$ to $\sim \!13.7$) versus separator thickness $t$ on a logarithmic $x$-axis ($10^{-6}$ to $1$). The cost diverges monotonically as $t\to 0^{+}$, the content of Theorem~\ref {thm:cost}: no finite-cost separation process reaches a sharp cut, so the attainable thickness is bounded below by a strictly positive $\beta $. (\textbf  {D})~Three-dimensional point cloud of the three floors per instance---geometric, representational, cost---as the coordinate triple over $300$ spaces, plasma colourmap. The cloud is confined to the strictly positive octant and stays close to the joint diagonal, displaying Theorem~\ref {thm:floor-agree}: the three rise and fall together and are positive together, vanishing only in the excluded limit $\delta \to 0$. Viewing angle: elevation $20^{\circ }$, azimuth $-50^{\circ }$.}}{13}{figure.3}\protected@file@percent }
\newlabel{fig:panel-floor-agreement}{{3}{13}{\textbf {The three derivations of the floor bound one constant.} (\textbf {A})~Representational floor on the linear $y$-axis ($1.5$ to $8$) versus geometric floor on the linear $x$-axis ($1.5$ to $24$), one point per instance ($300$ spaces), with the equality diagonal (red). Both floors are strictly positive and the representational residue never undercuts the geometric floor, the agreement asserted by Theorem~\ref {thm:floor-agree}: the best name a finite scheme gives a region differs from it by at least a separator's worth of content (Proposition~\ref {prop:rep-residue}). (\textbf {B})~Cost floor on the linear $y$-axis ($0.5$ to $8$) versus geometric floor on the linear $x$-axis ($1.5$ to $24$), $300$ instances, equality diagonal (red). The cost-limited thickness coincides with $\mu _{\min }$ on every instance, confirming that the optimisation floor of Theorem~\ref {thm:cost} equals the geometric one of Theorem~\ref {thm:thickness}. (\textbf {C})~The refinement cost $g(t)=-\log t$ on the linear $y$-axis ($0$ to $\sim \!13.7$) versus separator thickness $t$ on a logarithmic $x$-axis ($10^{-6}$ to $1$). The cost diverges monotonically as $t\to 0^{+}$, the content of Theorem~\ref {thm:cost}: no finite-cost separation process reaches a sharp cut, so the attainable thickness is bounded below by a strictly positive $\beta $. (\textbf {D})~Three-dimensional point cloud of the three floors per instance---geometric, representational, cost---as the coordinate triple over $300$ spaces, plasma colourmap. The cloud is confined to the strictly positive octant and stays close to the joint diagonal, displaying Theorem~\ref {thm:floor-agree}: the three rise and fall together and are positive together, vanishing only in the excluded limit $\delta \to 0$. Viewing angle: elevation $20^{\circ }$, azimuth $-50^{\circ }$}{figure.3}{}}
\newlabel{fig:panel-floor-agreement@cref}{{[figure][3][]3}{[1][12][]13}{}{}{}}
