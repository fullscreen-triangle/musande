\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The Boundary--Thickness Theorem: every realisable separator clears the floor.} (\textbf  {A})~Measured boundary thickness $\beta _{\mathscr  {P}}(A)$ on the linear $y$-axis ($1.5$ to $72$) versus the minimum cell measure $\mu _{\min }$ on the linear $x$-axis ($0.5$ to $8$), one point per realisable region over $\sim \!400$ instances ($15{,}057$ regions). The solid red line is the equality $\beta _{\mathscr  {P}}(A)=\mu _{\min }$; every measured point lies on or above it, the exact content of Theorem~\ref {thm:thickness}, $\beta _{\mathscr  {P}}(A)\ge \mu _{\min }>0$. No point falls below the line, so no realisable separator is sharp. (\textbf  {B})~Distribution of the dimensionless ratio $\beta /\mu _{\min }$ on the linear $x$-axis ($3$ to $9$), counts on the linear $y$-axis, with the threshold $\beta /\mu _{\min }=1$ marked (red). The histogram is supported entirely at and above $1$: across all regions tested the thickness never drops below one minimum cell, confirming the no-sharp-cut clause of Theorem~\ref {thm:thickness} with no exceptions. (\textbf  {C})~Boundary thickness $\beta _{\mathscr  {P}}(A)$ on the linear $y$-axis ($1.5$ to $72$) versus region scale $\sigma (A)=\mu (A)$ on the linear $x$-axis ($0.5$ to $48$). Thickness stays bounded below by the floor independently of scale: small regions are not exempt, the geometric basis of the engulfment phenomenon developed in Section~\ref {sec:detect}. (\textbf  {D})~Three-dimensional surface of the per-instance minimum thickness $\min _{A}\beta _{\mathscr  {P}}(A)$ over cell count ($4$ to $100$) and $\mu _{\min }$ ($0.5$ to $8$), $400$ instances, viridis colourmap. The surface is strictly positive everywhere (minimum elevation $1.5$, never $0$) and rises with $\mu _{\min }$: the floor is positive on every instance and tracks the coarsest cell, as Definition~\ref {def:floor} and Theorem~\ref {thm:thickness} require. Viewing angle: elevation $22^{\circ }$, azimuth $-60^{\circ }$.}}{8}{figure.1}\protected@file@percent }
\newlabel{fig:panel-thickness}{{1}{8}{\textbf {The Boundary--Thickness Theorem: every realisable separator clears the floor.} (\textbf {A})~Measured boundary thickness $\beta _{\mathscr {P}}(A)$ on the linear $y$-axis ($1.5$ to $72$) versus the minimum cell measure $\mu _{\min }$ on the linear $x$-axis ($0.5$ to $8$), one point per realisable region over $\sim \!400$ instances ($15{,}057$ regions). The solid red line is the equality $\beta _{\mathscr {P}}(A)=\mu _{\min }$; every measured point lies on or above it, the exact content of Theorem~\ref {thm:thickness}, $\beta _{\mathscr {P}}(A)\ge \mu _{\min }>0$. No point falls below the line, so no realisable separator is sharp. (\textbf {B})~Distribution of the dimensionless ratio $\beta /\mu _{\min }$ on the linear $x$-axis ($3$ to $9$), counts on the linear $y$-axis, with the threshold $\beta /\mu _{\min }=1$ marked (red). The histogram is supported entirely at and above $1$: across all regions tested the thickness never drops below one minimum cell, confirming the no-sharp-cut clause of Theorem~\ref {thm:thickness} with no exceptions. (\textbf {C})~Boundary thickness $\beta _{\mathscr {P}}(A)$ on the linear $y$-axis ($1.5$ to $72$) versus region scale $\sigma (A)=\mu (A)$ on the linear $x$-axis ($0.5$ to $48$). Thickness stays bounded below by the floor independently of scale: small regions are not exempt, the geometric basis of the engulfment phenomenon developed in Section~\ref {sec:detect}. (\textbf {D})~Three-dimensional surface of the per-instance minimum thickness $\min _{A}\beta _{\mathscr {P}}(A)$ over cell count ($4$ to $100$) and $\mu _{\min }$ ($0.5$ to $8$), $400$ instances, viridis colourmap. The surface is strictly positive everywhere (minimum elevation $1.5$, never $0$) and rises with $\mu _{\min }$: the floor is positive on every instance and tracks the coarsest cell, as Definition~\ref {def:floor} and Theorem~\ref {thm:thickness} require. Viewing angle: elevation $22^{\circ }$, azimuth $-60^{\circ }$}{figure.1}{}}
\newlabel{fig:panel-thickness@cref}{{[figure][1][]1}{[1][7][]8}{}{}{}}
