\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Ensemble Kuramoto and the Operational Bands at Ensemble Level.} (\textbf  {A})~Ensemble Kuramoto order parameter $R_{\rm  ens}$ on the linear $y$-axis versus uniform individual order parameter $R_i$ on the linear $x$-axis ($0$ to $1$), for an ensemble of $n=10$ agents with phases evenly distributed in $[0,\pi ]$. The four band cut-offs are marked (crimson dashed). The relationship is monotonic but sub-linear because of partial phase cancellation. The bands are the same operational labels of \Cref  {def:bands} read on $R_{\rm  ens}$. (\textbf  {B})~Synchronisation onset: $R_{\rm  ens}$ vs inter-agent coupling $K$ for natural-frequency spread $\sigma _\omega =1$. Below the critical coupling $K_c$ (crimson dashed) $R_{\rm  ens}=0$ (no synchronisation); above $K_c$, $R_{\rm  ens}$ rises, crossing the phase-lock cut-off $0.95$ (steelblue dashed). The onset is the mean-field bifurcation of \Cref  {thm:Kc} applied at the ensemble level (\Cref  {thm:ens-sync}). (\textbf  {C})~Phase distribution effect: bar chart comparing $R_{\rm  ens}$ for two phase distributions across ensemble sizes $n\in \{2,3,4,5,6,8\}$. Crimson bars (uniform phase distribution): $R_{\rm  ens}$ is small or zero, despite each agent having internal $R_i=1$. Seagreen bars (aligned phases): $R_{\rm  ens}=1$. Demonstrates the hierarchical independence noted after \Cref  {def:ens-R}: high $R_i$ does not imply high $R_{\rm  ens}$. (\textbf  {D})~Three-dimensional phase diagram: predicted $R_{\rm  ens}$ over $(n_{\rm  agents},\sigma _\omega )\in \{2,\dots  ,10\}\times [0.1,2.0]$ with fixed coupling $K=2$. The surface (viridis) shows that synchronisation strength decreases with frequency spread $\sigma _\omega $ (more diverse agents harder to synchronise) and is approximately independent of agent count when $K$ is fixed.}}{13}{figure.caption.6}\protected@file@percent }
\newlabel{fig:panel3-ensemble}{{3}{13}{\textbf {Ensemble Kuramoto and the Operational Bands at Ensemble Level.} (\textbf {A})~Ensemble Kuramoto order parameter $R_{\rm ens}$ on the linear $y$-axis versus uniform individual order parameter $R_i$ on the linear $x$-axis ($0$ to $1$), for an ensemble of $n=10$ agents with phases evenly distributed in $[0,\pi ]$. The four band cut-offs are marked (crimson dashed). The relationship is monotonic but sub-linear because of partial phase cancellation. The bands are the same operational labels of \Cref {def:bands} read on $R_{\rm ens}$. (\textbf {B})~Synchronisation onset: $R_{\rm ens}$ vs inter-agent coupling $K$ for natural-frequency spread $\sigma _\omega =1$. Below the critical coupling $K_c$ (crimson dashed) $R_{\rm ens}=0$ (no synchronisation); above $K_c$, $R_{\rm ens}$ rises, crossing the phase-lock cut-off $0.95$ (steelblue dashed). The onset is the mean-field bifurcation of \Cref {thm:Kc} applied at the ensemble level (\Cref {thm:ens-sync}). (\textbf {C})~Phase distribution effect: bar chart comparing $R_{\rm ens}$ for two phase distributions across ensemble sizes $n\in \{2,3,4,5,6,8\}$. Crimson bars (uniform phase distribution): $R_{\rm ens}$ is small or zero, despite each agent having internal $R_i=1$. Seagreen bars (aligned phases): $R_{\rm ens}=1$. Demonstrates the hierarchical independence noted after \Cref {def:ens-R}: high $R_i$ does not imply high $R_{\rm ens}$. (\textbf {D})~Three-dimensional phase diagram: predicted $R_{\rm ens}$ over $(n_{\rm agents},\sigma _\omega )\in \{2,\dots ,10\}\times [0.1,2.0]$ with fixed coupling $K=2$. The surface (viridis) shows that synchronisation strength decreases with frequency spread $\sigma _\omega $ (more diverse agents harder to synchronise) and is approximately independent of agent count when $K$ is fixed}{figure.caption.6}{}}
\newlabel{fig:panel3-ensemble@cref}{{[figure][3][]3}{[1][12][]13}{}{}{}}
