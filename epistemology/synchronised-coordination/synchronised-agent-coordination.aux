\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Partition Extinction and the Congruence of Phase-Locked Trajectories.} (\textbf  {A})~Categorical filtering geometries: angular field magnitude in the $(x,y)$ plane for the multipole orders $\ell =0$ (isotropic, steelblue), $\ell =1$ (two lobes, seagreen), and $\ell =2$ (four lobes, darkorange), the angular index of the partition coordinates $(n,\ell ,m,s)$ of \Cref  {def:partition-coords}. These illustrate the categorical observables of \Cref  {def:observables} on which distinguishability is defined. (\textbf  {B})~Pairwise categorical-indistinguishability matrix for a $5$-agent phase-locked ensemble ($\phi _i=\phi _j$ for all pairs): green entries mark pairs that are categorically indistinguishable. The matrix is uniformly green, the content of \Cref  {prop:correspondence}: in a phase-locked ensemble every pair is categorically indistinguishable and the inter-agent partition lag vanishes (\Cref  {thm:extinction}). (\textbf  {C})~Trajectory traces $M(t)=\DOTSI \intop \ilimits@ _0^t g(t')\,\,\mathrm  {d}t'$ for four phase-locked agents driven by a common field with small ($\sigma =0.02$) per-agent noise; the four trajectories are nearly indistinguishable within a tolerance set by the noise. This illustrates the structural correspondence of \Cref  {prop:correspondence}: congruence of coordinated trajectories is a \emph  {consequence} of synchronisation, and---by the observable-commutation theorem (\Cref  {thm:commutation})---is functional (categorical) equivalence, not loss of physical identity. (\textbf  {D})~Three-dimensional synchronisation diagram: stable order parameter $R^*=\sqrt  {1-K_c/K}$ over $(K,\sigma _\omega )\in [0.1,4]\times [0.1,2.0]$, $25\times 25$ grid, viridis colourmap, with $K_c=2/[\pi g(0)]$ of \Cref  {thm:Kc}. The surface rises with coupling $K$ and falls with frequency spread $\sigma _\omega $; it is zero on the critical-coupling locus $K=K_c$, above which synchronisation is possible.}}{18}{figure.caption.14}\protected@file@percent }
\newlabel{fig:panel5-extinction}{{5}{18}{\textbf {Partition Extinction and the Congruence of Phase-Locked Trajectories.} (\textbf {A})~Categorical filtering geometries: angular field magnitude in the $(x,y)$ plane for the multipole orders $\ell =0$ (isotropic, steelblue), $\ell =1$ (two lobes, seagreen), and $\ell =2$ (four lobes, darkorange), the angular index of the partition coordinates $(n,\ell ,m,s)$ of \Cref {def:partition-coords}. These illustrate the categorical observables of \Cref {def:observables} on which distinguishability is defined. (\textbf {B})~Pairwise categorical-indistinguishability matrix for a $5$-agent phase-locked ensemble ($\phi _i=\phi _j$ for all pairs): green entries mark pairs that are categorically indistinguishable. The matrix is uniformly green, the content of \Cref {prop:correspondence}: in a phase-locked ensemble every pair is categorically indistinguishable and the inter-agent partition lag vanishes (\Cref {thm:extinction}). (\textbf {C})~Trajectory traces $M(t)=\int _0^t g(t')\,\dd t'$ for four phase-locked agents driven by a common field with small ($\sigma =0.02$) per-agent noise; the four trajectories are nearly indistinguishable within a tolerance set by the noise. This illustrates the structural correspondence of \Cref {prop:correspondence}: congruence of coordinated trajectories is a \emph {consequence} of synchronisation, and---by the observable-commutation theorem (\Cref {thm:commutation})---is functional (categorical) equivalence, not loss of physical identity. (\textbf {D})~Three-dimensional synchronisation diagram: stable order parameter $R^*=\sqrt {1-K_c/K}$ over $(K,\sigma _\omega )\in [0.1,4]\times [0.1,2.0]$, $25\times 25$ grid, viridis colourmap, with $K_c=2/[\pi g(0)]$ of \Cref {thm:Kc}. The surface rises with coupling $K$ and falls with frequency spread $\sigma _\omega $; it is zero on the critical-coupling locus $K=K_c$, above which synchronisation is possible}{figure.caption.14}{}}
\newlabel{fig:panel5-extinction@cref}{{[figure][5][]5}{[1][17][]18}{}{}{}}
