\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Partition Extinction in the Categorical Model.} (\textbf  {A})~Inter-agent partition lag $\tau _p$ on the linear $y$-axis versus a normalised control parameter $\theta /\theta _c$ on the linear $x$-axis ($0.5$ to $2.5$), with critical value $\theta _c=1$ (crimson dashed). For $\theta <\theta _c$ (distinguishable) $\tau _p>0$; at phase-locking ($\phi _i=\phi _j$, $\theta \ge \theta _c$) $\tau _p\equiv 0$. The seagreen-shaded region is the partition-extinct phase. The discontinuous drop is the signature of the binary distinguishability of \Cref  {def:distinguishability}. Empirical content of \Cref  {thm:extinction} (partition extinction is discontinuous); as \Cref  {rem:correspondence-scope} states, the exact zero holds \emph  {in the categorical model}, real systems retaining a small positive lag. (\textbf  {B})~Coordination friction $\Theta _{\rm  coord}=\frac  1n\DOTSB \sum@ \slimits@ _{ij}\tau _p^{(ij)}G_{ij}$ on the linear $y$-axis versus the fraction of phase-locked pairs on the linear $x$-axis ($0$ to $1$). Friction falls to zero exactly when all pairs are phase-locked ($\phi _i=\phi _j$), the content of \Cref  {prop:correspondence}. The step reflects the binary distinguishability of \Cref  {def:distinguishability}: a pair is either distinguishable ($\tau _p>0$) or extinct ($\tau _p=0$), with no intermediate value. (This binary jump is a property of the pairwise lag, not a thermodynamic transition at any band cut-off; cf.\ \Cref  {prop:not-transitions}.) (\textbf  {C})~Pairwise categorical difference $d_{\rm  cat}(\mathsf  {A}_i,\mathsf  {A}_j)$ on the linear $y$-axis versus phase difference $|\phi _i-\phi _j|$ on the linear $x$-axis ($0$ to $2$): monotone (steelblue), reaching zero exactly at $\phi _i=\phi _j$ (seagreen dashed), where the pair becomes categorically indistinguishable (\Cref  {thm:extinction}, Step~2). (\textbf  {D})~Three-dimensional comparison of composite floor surfaces over $(n_{\rm  agents},f_{\rm  per-agent})\in \{2,\dots  ,10\}\times [0.5,5]$. Lower surface (viridis): independent agents under parallel composition, $S_{\flat }(\diamond )=\DOTSB \prod@ \slimits@ f_i/\Sigma ^{n-1}$ (decreases with $n$). Upper surface (plasma): synchronised agents, $S_{\flat }=S_{\flat }(\mathsf  {A}_1)$ (constant in $n$). The two surfaces meet only at $n=1$; for $n\ge 2$ independent composition is strictly lower (more agents help) but synchronised composition is constant (more agents add no further benefit, but also no friction).}}{15}{figure.caption.7}\protected@file@percent }
\newlabel{fig:panel4-sync}{{4}{15}{\textbf {Partition Extinction in the Categorical Model.} (\textbf {A})~Inter-agent partition lag $\tau _p$ on the linear $y$-axis versus a normalised control parameter $\theta /\theta _c$ on the linear $x$-axis ($0.5$ to $2.5$), with critical value $\theta _c=1$ (crimson dashed). For $\theta <\theta _c$ (distinguishable) $\tau _p>0$; at phase-locking ($\phi _i=\phi _j$, $\theta \ge \theta _c$) $\tau _p\equiv 0$. The seagreen-shaded region is the partition-extinct phase. The discontinuous drop is the signature of the binary distinguishability of \Cref {def:distinguishability}. Empirical content of \Cref {thm:extinction} (partition extinction is discontinuous); as \Cref {rem:correspondence-scope} states, the exact zero holds \emph {in the categorical model}, real systems retaining a small positive lag. (\textbf {B})~Coordination friction $\Theta _{\rm coord}=\frac 1n\sum _{ij}\tau _p^{(ij)}G_{ij}$ on the linear $y$-axis versus the fraction of phase-locked pairs on the linear $x$-axis ($0$ to $1$). Friction falls to zero exactly when all pairs are phase-locked ($\phi _i=\phi _j$), the content of \Cref {prop:correspondence}. The step reflects the binary distinguishability of \Cref {def:distinguishability}: a pair is either distinguishable ($\tau _p>0$) or extinct ($\tau _p=0$), with no intermediate value. (This binary jump is a property of the pairwise lag, not a thermodynamic transition at any band cut-off; cf.\ \Cref {prop:not-transitions}.) (\textbf {C})~Pairwise categorical difference $d_{\rm cat}(\agent _i,\agent _j)$ on the linear $y$-axis versus phase difference $|\phi _i-\phi _j|$ on the linear $x$-axis ($0$ to $2$): monotone (steelblue), reaching zero exactly at $\phi _i=\phi _j$ (seagreen dashed), where the pair becomes categorically indistinguishable (\Cref {thm:extinction}, Step~2). (\textbf {D})~Three-dimensional comparison of composite floor surfaces over $(n_{\rm agents},f_{\rm per-agent})\in \{2,\dots ,10\}\times [0.5,5]$. Lower surface (viridis): independent agents under parallel composition, $\Sfloor (\Compose )=\prod f_i/\Sigma ^{n-1}$ (decreases with $n$). Upper surface (plasma): synchronised agents, $\Sfloor =\Sfloor (\agent _1)$ (constant in $n$). The two surfaces meet only at $n=1$; for $n\ge 2$ independent composition is strictly lower (more agents help) but synchronised composition is constant (more agents add no further benefit, but also no friction)}{figure.caption.7}{}}
\newlabel{fig:panel4-sync@cref}{{[figure][4][]4}{[1][14][]15}{}{}{}}
