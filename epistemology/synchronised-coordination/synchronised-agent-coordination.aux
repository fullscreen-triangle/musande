\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Aperture Sharing and Memory Compatibility.} (\textbf  {A})~Aperture multipole patterns: angular field magnitude in the $(x,y)$ plane for monopole ($\ell =0$, isotropic, steelblue), dipole ($\ell =1$, two lobes, seagreen), and quadrupole ($\ell =2$, four lobes, darkorange). Each multipole order corresponds to a distinct categorical filtering geometry as defined in \Cref  {def:aper}. Phase-lock requires shared multipole order. (\textbf  {B})~Aperture sharing matrix for a $5$-agent phase-locked ensemble (all dipole apertures $\ell =1$): green entries indicate isomorphism between agent $i$ and agent $j$ apertures. The matrix is uniformly green, confirming Theorem~\ref {thm:aper-share}: phase-locked agents share apertures pairwise. (\textbf  {C})~Memory traces $M(t)=\DOTSI \intop \ilimits@ _0^t\dot  {H}^+\,\mathrm  {d}t'$ for four phase-locked agents processing a common $H^+$-field with small ($\sigma =0.02$) per-agent noise. The four trajectories are nearly indistinguishable, demonstrating Theorem~\ref {thm:mem-compat}: phase-locked agents have memory traces congruent within tolerance $\varepsilon _{\rm  mem}$. Coordinated teams ``remember the same things'' as a consequence of synchronisation, not as a prerequisite. (\textbf  {D})~Three-dimensional synchronisation phase diagram: stable order parameter $R^*=\sqrt  {1-K_c/K}$ over $(K,\sigma _\omega )\in [0.1,4]\times [0.1,2.0]$, $25\times 25$ grid, viridis colourmap. The surface rises with coupling $K$ (synchronisation strengthens) and falls with frequency spread $\sigma _\omega $ (heterogeneity hinders synchronisation). The surface is zero on the line $K=K_c=2\sigma _\omega /\pi $ (the critical-coupling locus); above this line synchronisation is possible.}}{16}{figure.caption.7}\protected@file@percent }
\newlabel{fig:panel5-aperture-memory}{{5}{16}{\textbf {Aperture Sharing and Memory Compatibility.} (\textbf {A})~Aperture multipole patterns: angular field magnitude in the $(x,y)$ plane for monopole ($\ell =0$, isotropic, steelblue), dipole ($\ell =1$, two lobes, seagreen), and quadrupole ($\ell =2$, four lobes, darkorange). Each multipole order corresponds to a distinct categorical filtering geometry as defined in \Cref {def:aper}. Phase-lock requires shared multipole order. (\textbf {B})~Aperture sharing matrix for a $5$-agent phase-locked ensemble (all dipole apertures $\ell =1$): green entries indicate isomorphism between agent $i$ and agent $j$ apertures. The matrix is uniformly green, confirming Theorem~\ref {thm:aper-share}: phase-locked agents share apertures pairwise. (\textbf {C})~Memory traces $M(t)=\int _0^t\dot {H}^+\dd t'$ for four phase-locked agents processing a common $H^+$-field with small ($\sigma =0.02$) per-agent noise. The four trajectories are nearly indistinguishable, demonstrating Theorem~\ref {thm:mem-compat}: phase-locked agents have memory traces congruent within tolerance $\eps _{\rm mem}$. Coordinated teams ``remember the same things'' as a consequence of synchronisation, not as a prerequisite. (\textbf {D})~Three-dimensional synchronisation phase diagram: stable order parameter $R^*=\sqrt {1-K_c/K}$ over $(K,\sigma _\omega )\in [0.1,4]\times [0.1,2.0]$, $25\times 25$ grid, viridis colourmap. The surface rises with coupling $K$ (synchronisation strengthens) and falls with frequency spread $\sigma _\omega $ (heterogeneity hinders synchronisation). The surface is zero on the line $K=K_c=2\sigma _\omega /\pi $ (the critical-coupling locus); above this line synchronisation is possible}{figure.caption.7}{}}
\newlabel{fig:panel5-aperture-memory@cref}{{[figure][5][]5}{[1][15][]16}{}{}{}}
